enum OrderStatus {
  pending
  paid
  shipped
  delivered
  cancelled
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @db.Char(26) @default(dbgenerated())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  password      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt @default(now())

  roleId        String?
  role          Role?           @relation(fields: [roleId], references: [id])

  bio             Bio?
  workExperience  WorkExperience[]
  social        SocialLink[]
  skills        Skill[]
  accounts      Account[]
  notifications Notification[]
  posts         Post[]
  sessions      Session[]
  cartItems     Cart[]
  orders        Order[]
  logs          Log[]
  settings      Settings[]
  wishlists     Wishlist[]
  addresses     Address[]

  @@index([email])
}

model Role {
  id          String          @id @db.Char(26) @default(dbgenerated())
  name        String          @unique
  permissions Permission[]
  users       User[]
}

model Bio {
  id          String      @id @db.Char(26) @default(dbgenerated())
  text        String

  userId      String    @unique
  users       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialLink {
  id          String      @id @db.Char(26) @default(dbgenerated())
  name        String
  text        String

  userId      String    @unique
  users       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Skill {
  id          String      @id @db.Char(26) @default(dbgenerated())
  text        String

  userId      String    
  users User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([text, userId])
}

model WorkExperience {
  id            String      @id @db.Char(26) @default(dbgenerated())
  jobTitle      String
  companyName   String
  dates         String
  duties        String

  userId        String 
  users         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobTitle, companyName])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String       @id @db.Char(26) @default(dbgenerated())
  sessionToken String       @unique
  userId       String
  expires      DateTime
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id        String          @id @db.Char(26) @default(dbgenerated())
  title     String
  content   String?
  published Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt @default(now())
  deletedAt DateTime?
  
  authorId  String
  author    User            @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model Notification {
  id        String          @id @db.Char(26) @default(dbgenerated())
  title     String
  body      String
  read      Boolean         @default(false)
  userId    String?
  createdAt DateTime        @default(now())
  user      User?           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([read])
}

model Permission {
  path   String
  id     String             @id @db.Char(26) @default(dbgenerated())
  roleId String
  role   Role               @relation(fields: [roleId], references: [id])
}

model Privatemessage {
  id        String   @id @db.Char(26) @default(dbgenerated())
  names     String
  email     String
  message   String

  read      Boolean  @default(false)
  archived  Boolean  @default(false) 
  deletedAt DateTime? @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt     @default(now())

  @@index([read])
  @@index([createdAt])
}

model Cart {
  id            String      @id @db.Char(26) @default(dbgenerated())
  user          User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt @default(now())
  deletedAt     DateTime?

  cartItems CartItem[]

  @@unique([userId]) // one entry per user per item
  @@index([createdAt])
}

model CartItem {
  id            String      @id @db.Char(26) @default(dbgenerated())
  cart          Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId        String
  quantity      Int

  merchandiseId String
  merchandise Merchandise @relation(fields: [merchandiseId], references: [id], onDelete: Cascade)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt @default(now())

  @@unique([cartId, merchandiseId]) // prevent duplicate items in cart
}

model Merchandise {
  id        String          @id @db.Char(26) @default(dbgenerated())
  title     String          @unique
  price     Decimal         @db.Decimal(10, 2)
  body      String
  createdAt DateTime        @default(now()) 
  deletedAt DateTime?       @default(now()) 

  
  cartItems CartItem[]

  wishlists Wishlist[]

  orderItems OrderItem[]
}

model Order {
  id              String        @id @db.Char(26) @default(dbgenerated())

  userId          String
  user            User          @relation(fields: [userId], references: [id])

  status          OrderStatus   @default(pending)
  paymentStatus   PaymentStatus @default(PENDING)

  totalAmount     Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")

  paymentRef      String?       @unique // EcoCash / gateway reference

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt @default(now()) 

  archived        Boolean       @default(false)
  archivedAt      DateTime?     @default(now()) 

  // ✅ Correct relations
  items           OrderItem[]
  shippingAddress ShippingAddress?

  payments        Payment[]

  @@index([createdAt])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id            String      @id @default(dbgenerated())

  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  merchandiseId String
  merchandise   Merchandise @relation(fields: [merchandiseId], references: [id])

  title         String      // snapshot (important!)
  price         Decimal     @db.Decimal(10, 2) // snapshot price

  quantity      Int

  createdAt     DateTime    @default(now())
}

model Payment {
  id          String        @id @db.Char(26) @default(dbgenerated())

  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String

  amount      Decimal       @db.Decimal(10,2)
  method      String        // e.g. "stripe", "paynow", "ecocash"

  status      PaymentStatus        @default(PENDING) // initiated, successful, failed, refunded
  transactionRef String?    @unique// gateway reference
  pollUrl       String?     @unique

  paidAt        DateTime?   @default(now()) 
  expiresAt     DateTime?   @default(now()) 

  rawWebhook    Json?    // 🔥 store payload for debugging

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt    @default(now()) 

  @@index([status])
  @@index([orderId])
}

model ShippingAddress {
  id        String          @id @db.Char(26) @default(dbgenerated())

  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String          @unique         

  fullName  String          
  street    String
  city      String
  state     String?
  postalCode String?
  country   String
  phone     String?

  createdAt DateTime        @default(now())
}

model Wishlist {
  id        String          @id @db.Char(26) @default(dbgenerated())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  merchandise Merchandise   @relation(fields: [merchandiseId], references: [id], onDelete: Cascade)
  merchandiseId String

  createdAt DateTime        @default(now())

  @@unique([userId, merchandiseId]) // prevent duplicates
  @@index([userId])
}

model Log {
  id        String          @id @db.Char(26) @default(dbgenerated())
  action    String          // e.g. "USER_ROLE_CHANGE", "ORDER_PLACED"
  userId    String?
  user      User?           @relation(fields: [userId], references: [id])
  details   Json?
  createdAt DateTime        @default(now())
  archived  Boolean         @default(false)
  archivedAt DateTime?      @default(now()) 

  @@index([action, createdAt])
}

model Settings {
  id        String          @id @db.Char(26) @default(dbgenerated())
  userId    String          @unique
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String          @default("light") // light/dark
  language  String          @default("en")
  notifyByEmail Boolean     @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt  @default(now()) 
}

model Address {
  id          String   @id @default(dbgenerated())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName    String
  street      String
  city        String
  state       String?
  postalCode  String?
  country     String
  phone       String?

  isDefault   Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([userId])
}
